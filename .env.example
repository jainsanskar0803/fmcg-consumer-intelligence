# ──────────────────────────────────────────────────────────────────────────────
#  FMCG Consumer Intelligence Platform — Environment Configuration
#  HOW TO USE:  cp .env.example .env  →  fill in keys  →  streamlit run app.py
# ──────────────────────────────────────────────────────────────────────────────

# ── AI PROVIDER ───────────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# Google Gemini — free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Groq (alternative) — free key at https://console.groq.com
# AI_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama3-8b-8192

# ── MONGODB ATLAS ─────────────────────────────────────────────────────────────
# IMPORTANT: wrap the URI in quotes so the & character is handled correctly
MONGO_URI="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/fmcg_intelligence?retryWrites=true&w=majority"
MONGO_DB_NAME=fmcg_intelligence

# Local MongoDB (if not using Atlas):
# MONGO_URI=mongodb://localhost:27017/

# ── CHROMADB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
